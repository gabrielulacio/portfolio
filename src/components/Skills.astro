---

import { Icon } from 'astro-icon/components';

interface Skill {
  name: string;
  icon: string;
}

interface SkillGroup {
  category: string;
  skills: Skill[];
}

const skillGroups: SkillGroup[] = [
  {
    category: 'Lenguajes',
    skills: [
      
      { name: 'Python',     icon: 'simple-icons:python'     },
      { name: 'SQL',        icon: 'mdi:database'            },
      { name: 'JavaScript', icon: 'simple-icons:javascript' },
      { name: 'C++',        icon: 'simple-icons:cplusplus'  },
      { name: 'Java',       icon: 'simple-icons:oracle'     },
    ],
  },
  {
    category: 'Frontend & UI',
    skills: [
      { name: 'React.js',    icon: 'simple-icons:react'       },
      { name: 'Vue.js',      icon: 'simple-icons:vuedotjs'    },
      { name: 'Astro',       icon: 'simple-icons:astro'       },
      { name: 'Tailwind CSS',icon: 'simple-icons:tailwindcss' },
      { name: 'Figma',       icon: 'simple-icons:figma'       },
    ],
  },
  {
    category: 'Bases de Datos',
    skills: [
      { name: 'PostgreSQL', icon: 'simple-icons:postgresql' },
      { name: 'MySQL',      icon: 'simple-icons:mysql'      },
      { name: 'Oracle DB',  icon: 'simple-icons:oracle'     },
      { name: 'MongoDB',    icon: 'simple-icons:mongodb'    },
    ],
  },
  {
    category: 'Herramientas',
    skills: [
      { name: 'Git / GitHub', icon: 'simple-icons:git'    },
      { name: 'HTML5',        icon: 'simple-icons:html5'   },
      { name: 'CSS3',         icon: 'simple-icons:css3'    },
      { name: 'Prompt Eng.',  icon: 'mdi:robot-outline'    },
    ],
  },
];
---

<section
  id="habilidades"
  class="border-t border-[#2D2D2D] mx-auto max-w-6xl px-6 py-24"
  aria-labelledby="skills-heading"
>

  <!-- Section header  -->
  <div class="mb-12 flex flex-col gap-3">
    <span class="font-mono text-xs text-[#ACE600] uppercase tracking-widest">
      // habilidades técnicas
    </span>
    <h2
      id="skills-heading"
      class="text-3xl sm:text-4xl font-bold text-[#F1F1F1] tracking-tight"
    >
      Habilidades
    </h2>
    <div class="w-12 h-px bg-[#ACE600] mt-1"></div>
  </div>

  <!-- Skill groups -->
  <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    {skillGroups.map(({ category, skills }) => (
      <div class="flex flex-col gap-4">
        <!-- Category label -->
        <h3 class="font-mono text-xs uppercase tracking-widest text-[#A3A3A3] border-b border-[#2D2D2D] pb-2">
          {category}
        </h3>

        <!-- Skill chips -->
        <ul class="flex flex-col gap-2" role="list">
          {skills.map(({ name, icon }) => (
            <li class="flex items-center gap-3 group">
              <span
                class="p-1.5 rounded bg-[#0A0A0A] border border-[#2D2D2D] text-[#A3A3A3]
                       group-hover:border-[#ACE600]/50 group-hover:text-[#ACE600]
                       transition-all duration-200"
                aria-hidden="true"
              >
                <Icon name={icon} class="w-4 h-4" />
              </span>
              <span class="text-sm text-[#A3A3A3] group-hover:text-[#F1F1F1] transition-colors duration-200">
                {name}
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

</section>
