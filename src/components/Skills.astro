---
import SectionHeader from './ui/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

interface Skill {
  name: string;
  icon: string;
}

interface SkillGroup {
  category: string;
  skills: Skill[];
}

const skillGroups: SkillGroup[] = [
  {
    category: 'Frontend & UI',
    skills: [
      { name: 'Vue.js',       icon: 'simple-icons:vuedotjs'     },
      { name: 'Astro',        icon: 'simple-icons:astro'        },
      { name: 'JavaScript',   icon: 'simple-icons:javascript'   },
      { name: 'Tailwind CSS', icon: 'simple-icons:tailwindcss'  },
      { name: 'HTML5 & CSS3', icon: 'simple-icons:html5'        },
      { name: 'Figma',        icon: 'simple-icons:figma'        },
    ],
  },
  {
    category: 'Backend & Datos',
    skills: [
      { name: 'Python',       icon: 'simple-icons:python'       },
      { name: 'FastAPI',      icon: 'simple-icons:fastapi'      },
      { name: 'PostgreSQL',   icon: 'simple-icons:postgresql'   },
      { name: 'MongoDB',      icon: 'simple-icons:mongodb'      },
      { name: 'SQL',          icon: 'mdi:database'              },
      { name: 'Supabase',     icon: 'simple-icons:supabase'     },
    ],
  },
  {
    category: 'Herramientas & Flujos',
    skills: [
      { name: 'Docker',       icon: 'simple-icons:docker'       },
      { name: 'Git',          icon: 'simple-icons:git'          },
      { name: 'GitHub',       icon: 'simple-icons:github'       },
      { name: 'VS Code',      icon: 'simple-icons:visualstudiocode' },
      { name: 'Terminal',     icon: 'mdi:console'               },
    ],
  },
];
---

<section
  id="habilidades"
  class="mx-auto max-w-6xl px-6 py-24"
  style="border-top: 1px solid var(--color-border);"
  aria-labelledby="skills-heading"
>
  <SectionHeader label="// stack técnico" title="Habilidades" />

  <div
    class="grid gap-8 md:grid-cols-3"
  >
    {skillGroups.map(({ category, skills }, gi) => (
      <div
        class="sr flex flex-col gap-4 items-center"
        style={`transition-delay: ${gi * 150}ms;`}
      >
        <h3
          class="text-xs font-medium uppercase tracking-[0.12em] pb-3 text-center w-full"
          style="
            color: var(--color-text-muted);
            font-family: var(--font-display);
            border-bottom: 1px solid var(--color-border);
          "
        >
          {category}
        </h3>

        <ul class="flex flex-col gap-1" role="list">
          {skills.map(({ name, icon }, si) => (
            <li
              class="skill-item sr flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-200"
              style={`transition-delay: ${gi * 150 + si * 60}ms;`}
            >
              <Icon
                name={icon}
                class="skill-icon w-4 h-4 shrink-0 transition-all duration-200"
                style="color: var(--color-text-muted);"
                aria-hidden="true"
              />
              <span
                class="skill-name text-sm transition-all duration-200"
                style="color: var(--color-text-muted);"
              >
                {name}
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .skill-item:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .skill-item:hover .skill-icon {
    color: var(--color-accent) !important;
    filter: drop-shadow(0 0 4px color-mix(in srgb, var(--color-accent) 60%, transparent));
    transform: scale(1.2);
  }

  .skill-item:hover .skill-name {
    color: var(--color-text) !important;
    font-weight: 500;
  }
</style>

<script>
  import { initScrollReveal } from '../scripts/scroll-reveal.ts';
  initScrollReveal();
</script>
