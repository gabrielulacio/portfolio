---
import FloatingShapes from './ui/FloatingShapes.astro';
import Logo from './ui/Logo.astro';
---

<section
  id="hero"
  class="relative overflow-hidden flex items-center"
  style="min-height: 100vh; padding-top: 72px;"
  aria-label="Introduction"
>
  <FloatingShapes />

  <!-- Watermark logo -->
  <div
    class="watermark-logo"
    aria-hidden="true"
    style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; z-index: 0; opacity: 0; animation: fadeInWatermark 1.5s ease 0.5s forwards;"
  >
    <Logo size={500} color="#ffffff" />
  </div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto max-w-[820px] w-full px-6 py-12 flex flex-col items-center text-center"
    style="gap: 28px;"
  >

    <!-- Available badge -->
    <div
      class="hero-badge flex items-center gap-2 px-4 py-2 rounded-full"
      style="
        border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
        opacity: 0;
        animation: fadeUp 0.7s ease 0.2s forwards;
      "
    >
      <span
        class="w-2 h-2 rounded-full"
        style="
          background: var(--color-accent);
          box-shadow: 0 0 8px var(--color-accent);
          animation: pulse-dot 2s infinite;
        "
      ></span>
      <span
        class="text-xs font-medium uppercase tracking-[0.12em]"
        style="color: var(--color-accent); font-family: var(--font-display);"
      >
        Disponible para trabajar
      </span>
    </div>

    <!-- Heading -->
    <h1 class="sr-only">Gabriel Ulacio — Desarrollador Full-Stack</h1>
    <div class="flex flex-col items-center" style="gap: 8px;" aria-hidden="true">
      <div class="overflow-hidden">
        <p
          class="font-bold"
          style="
            font-size: clamp(32px, 6vw, 56px);
            letter-spacing: -0.02em;
            line-height: 1.1;
            opacity: 0;
            animation: slideUpReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s forwards;
            font-family: var(--font-display);
          "
        >
          Hola, soy
        </p>
      </div>
      <div class="overflow-hidden">
        <p
          class="font-bold"
          style="
            font-size: clamp(36px, 7vw, 64px);
            letter-spacing: -0.03em;
            line-height: 1.1;
            color: var(--color-cta);
            opacity: 0;
            animation: slideUpReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.42s forwards;
            font-family: var(--font-display);
          "
        >
          Gabriel Ulacio.
        </p>
      </div>
      <div class="overflow-hidden">
        <p
          class="font-bold"
          style="
            font-size: clamp(32px, 6vw, 56px);
            letter-spacing: -0.02em;
            line-height: 1.1;
            opacity: 0;
            animation: slideUpReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.54s forwards;
            font-family: var(--font-display);
          "
        >
          Desarrollador
        </p>
      </div>
      <div class="overflow-hidden">
        <p
          class="font-bold"
          style="
            font-size: clamp(32px, 6vw, 56px);
            letter-spacing: -0.02em;
            line-height: 1.1;
            opacity: 0;
            animation: slideUpReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.66s forwards;
            font-family: var(--font-display);
          "
        >
          Full-Stack.
        </p>
      </div>
    </div>

    <!-- Subtitle -->
    <p
      class="max-w-[560px] leading-relaxed"
      style="
        font-size: clamp(15px, 2vw, 18px);
        font-weight: 300;
        color: var(--color-text-muted);
        opacity: 0;
        animation: fadeUp 0.8s ease 0.9s forwards;
      "
    >
      Especializado en ecosistemas <strong style="color: var(--color-text); font-weight: 500;">Vue.js y Python</strong>. Construyo arquitecturas SaaS, APIs RESTful y soluciones de bases de datos optimizadas para despliegues en producción.
    </p>
    <!-- CTA buttons -->
    <div
      class="flex flex-wrap items-center justify-center gap-4"
      style="opacity: 0; animation: fadeUp 0.8s ease 1.1s forwards;"
    >
      <a
        href="/#proyectos"
        class="cta-primary inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm rounded-xl transition-all duration-200 active:scale-95"
        style="
          background: var(--color-cta);
          color: #1C1C1C;
          box-shadow: 0 0 20px color-mix(in srgb, var(--color-cta) 40%, transparent);
          font-family: var(--font-display);
        "
      >
        Ver Proyectos →
      </a>

      <a
        href="/#contacto"
        class="cta-outline inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm rounded-xl transition-all duration-200 active:scale-95"
        style="color: var(--color-text); font-family: var(--font-display);"
      >
        <span class="btn-label">Contáctame</span>
      </a>

      <a
        href="https://drive.google.com/file/d/1OL_2sjohfP1yiQmjlHIrAHggcKpjrMJj/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-outline inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm rounded-xl transition-all duration-200 active:scale-95"
        style="color: var(--color-text); font-family: var(--font-display);"
      >
        <span class="btn-label">Ver C.V.</span>
      </a>
    </div>

    <!-- Tech pills -->
    <div
      class="flex flex-wrap justify-center gap-3"
      aria-label="Tecnologías principales"
      style="opacity: 0; animation: fadeUp 0.8s ease 1.3s forwards;"
    >
      {['Vue.js', 'Python', 'FastAPI', 'PostgreSQL', 'Docker', 'Astro'].map((tech, i) => (
        <span
          class="tech-pill text-xs px-3 py-1 rounded-full cursor-default transition-all duration-200"
          style={`
            border: 1px solid var(--color-border);
            background: var(--color-bg-card);
            color: var(--color-text-muted);
            font-family: var(--font-display);
            animation-delay: ${1.5 + i * 0.08}s;
          `}
        >
          {tech}
        </span>
      ))}
    </div>

  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2"
    style="opacity: 0; animation: fadeIn 1s ease 2s forwards;"
    aria-hidden="true"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      style="color: var(--color-accent); animation: scrollBounce 2s ease-in-out infinite;"
    >
      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  @keyframes slideUpReveal {
    from { opacity: 0; transform: translateY(100%); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInWatermark {
    from { opacity: 0; }
    to   { opacity: 0.01; }
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 55px color-mix(in srgb, var(--color-cta) 70%, transparent);
  }

  .cta-outline {
    position: relative;
  }

  .cta-outline::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: var(--btn-border-gradient, var(--color-border));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    pointer-events: none;
  }

  .cta-outline:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .tech-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.cta-outline').forEach(btn => {
    const label = btn.querySelector<HTMLElement>('.btn-label');

    function applyGradient(x: string, y: string) {
      const g = `radial-gradient(circle at ${x}% ${y}%, #F39237 0%, #367588 70%)`;
      btn.style.setProperty('--btn-border-gradient', g);
      if (label) {
        label.style.backgroundImage = g;
        label.style.backgroundClip = 'text';
        label.style.webkitBackgroundClip = 'text';
        label.style.color = 'transparent';
      }
    }

    btn.addEventListener('mouseenter', () => applyGradient('50', '50'));
    btn.addEventListener('mousemove', (e) => {
      const r = btn.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width * 100).toFixed(1);
      const y = ((e.clientY - r.top) / r.height * 100).toFixed(1);
      applyGradient(x, y);
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.removeProperty('--btn-border-gradient');
      if (label) {
        label.style.backgroundImage = '';
        label.style.backgroundClip = '';
        label.style.webkitBackgroundClip = '';
        label.style.color = '';
      }
    });
  });
</script>
