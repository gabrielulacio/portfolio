---

import { Icon } from 'astro-icon/components';
---

<section
  id="hero"
  class="relative overflow-hidden min-h-[calc(100vh-4rem)] flex items-center"
  aria-label="Introduction"
>

  <!-- ── Decoración de fondo ─────────────── -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 flex items-center justify-center"
  >
    <div class="absolute w-[600px] h-[600px] rounded-full opacity-[0.07] blur-[120px] bg-[#ACE600] animate-pulse-slow"></div>
    <div class="absolute w-[300px] h-[300px] rounded-full opacity-[0.05] blur-[80px] bg-[#ACE600] translate-x-72 -translate-y-24"></div>
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(45,45,45,0.3)_1px,transparent_1px),linear-gradient(90deg,rgba(45,45,45,0.3)_1px,transparent_1px)] bg-[size:60px_60px]"
  ></div>

  <!-- Contenido -->
  <div class="relative z-10 mx-auto max-w-3xl w-full px-6 py-24 flex flex-col items-center text-center gap-8">

    <!-- Recuadro de arriba -->
    <div class="flex items-center justify-center gap-2 w-fit">
        <span class="font-mono text-xs text-[#ACE600] border border-[#ACE600]/30 rounded px-3 py-1 bg-[#ACE600]/5 tracking-widest uppercase">
          Disponible para trabajar
        </span>
      </div>

      <!-- Texto Principal -->
      <div class="flex flex-col gap-4 items-center">
        <h1 class="text-5xl sm:text-6xl lg:text-6xl font-bold tracking-tight leading-[1.15] text-[#F1F1F1] text-center">
          Hola, soy <br /><span class="text-[#ACE600] text-glow-accent">Gabriel Ulacio</span>.<br />
          Futuro Ingeniero
          en Informática.
        </h1>

        <p class="text-lg sm:text-xl text-[#A3A3A3] max-w-xl leading-relaxed font-light text-center">
          Estudiante avanzado de Ingeniería en Informática (UNET).
          Combino bases sólidas en
          <span class="text-[#F1F1F1]">arquitectura de software</span>.
          No solo escribo código; diseño sistemas escalables, interfaces modernas
          y entrego soluciones en
          <span class="text-[#F1F1F1]">tiempo récord</span>.
        </p>
      </div>

      <!-- Botones CTA -->
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/#proyectos"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#ACE600] text-[#0A0A0A] font-semibold text-sm rounded hover:bg-[#c4f500] active:scale-95 transition-all duration-200 glow-accent"
        >
          Ver Proyectos
          <Icon name="mdi:arrow-right" class="w-4 h-4" aria-hidden="true" />
        </a>

        <a
          href="/#contacto"
          class="inline-flex items-center gap-2 px-6 py-3 border border-[#2D2D2D] text-[#F1F1F1] font-semibold text-sm rounded hover:border-[#ACE600] hover:text-[#ACE600] active:scale-95 transition-all duration-200"
        >
          Contáctame
          <Icon name="mdi:email-outline" class="w-4 h-4" aria-hidden="true" />
        </a>

        <a
          href="https://drive.google.com/file/d/1gswEcukdqIXRBnKp2U8lBn2Rva_B_5SI/view?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 border border-[#2D2D2D] text-[#F1F1F1] font-semibold text-sm rounded hover:border-[#ACE600] hover:text-[#ACE600] active:scale-95 transition-all duration-200"
        >
          Ver C.V.
          <Icon name="mdi:file-account-outline" class="w-4 h-4" aria-hidden="true" />
        </a>
      </div>

      <!-- Tecnologías principales -->
      <div class="flex flex-wrap justify-center gap-3" aria-label="Tecnologías principales">
        {['Python','Astro', 'Vue.js', 'PostgreSQL', 'Tailwind CSS', 'React.js'].map((tech) => (
          <span class="font-mono text-xs text-[#A3A3A3] border border-[#2D2D2D] rounded px-3 py-1 bg-[#111111] hover:border-[#ACE600]/50 hover:text-[#ACE600] transition-colors duration-200 cursor-default">
            {tech}
          </span>
        ))}
      </div>
  </div>
</section>

<!-- Animaciones -->
<style>
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.07; transform: scale(1); }
    50%       { opacity: 0.12; transform: scale(1.08); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 6s ease-in-out infinite;
  }
</style>
