  width={width}
  height={size}
  viewBox="0 0 534 392"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Gabriel Ulacio logo"
>
  {!color && (
    <defs>
      <linearGradient id={uid} x1="0" y1="0" x2="534" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0%">
          <animate attributeName="stop-color"
            values="#367588;#F39237;#367588"
            dur="4s" repeatCount="indefinite" />
        </stop>
        <stop offset="100%">
          <animate attributeName="stop-color"
            values="#F39237;#367588;#F39237"
            dur="4s" repeatCount="indefinite" />
        </stop>
      </linearGradient>
    </defs>
