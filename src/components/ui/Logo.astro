---
interface Props {
  size?: number;
  color?: string;
}

const { size = 40, color } = Astro.props;
const scale = size / 392;
const width = Math.round(534 * scale);
const uid = `lg-${Math.random().toString(36).slice(2, 7)}`;
const fill = color ?? `url(#${uid})`;
---

