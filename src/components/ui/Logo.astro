---
interface Props {
  size?: number;
  color?: string;
}

const { size = 40, color } = Astro.props;
const uid = `lg-${Math.random().toString(36).slice(2, 7)}`;
const fill = color ?? `url(#${uid})`;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 800 800"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Gabriel Ulacio logo"
>
  {!color && (
    <defs>
      <linearGradient id={uid} x1="0" y1="0" x2="800" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0%">
          <animate attributeName="stop-color"
            values="#367588;#F39237;#367588"
            dur="4s" repeatCount="indefinite" />
        </stop>
        <stop offset="100%">
          <animate attributeName="stop-color"
            values="#F39237;#367588;#F39237"
            dur="4s" repeatCount="indefinite" />
        </stop>
      </linearGradient>
    </defs>
  )}
  <polygon
    fill={fill}
    points="134.69 330.1 336.35 213.69 336.38 353.41 376.72 330.13 376.72 143.82 54.01 330.16 175.03 400.03 54.01 469.87 376.69 656.18 376.72 469.87 296.04 423.28 255.7 446.59 336.38 493.15 336.38 586.34 336.35 586.34 134.69 469.84 255.67 400 134.69 330.1"
  />
  <polygon
    fill={fill}
    points="587.38 237.25 547.04 260.54 665.31 330.13 544.3 400 665.31 469.87 463.59 586.31 463.62 167.1 463.59 167.1 423.28 143.82 423.28 656.18 745.99 469.87 624.97 400 745.99 330.13 587.38 237.25"
  />
</svg>
