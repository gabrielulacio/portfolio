---

<div class="floating-shapes" aria-hidden="true">
  <!-- Blur orbs -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <!-- Grid overlay -->
  <div class="grid-overlay"></div>

  <!-- Geometric accents -->
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>
  <div class="shape shape-3"></div>
</div>

<style>
  .floating-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: var(--color-accent);
    opacity: 0.08;
    top: 10%;
    left: 15%;
    animation: pulseGlow 8s ease-in-out infinite;
  }

  .orb-2 {
    width: 350px;
    height: 350px;
    background: var(--color-cta);
    opacity: 0.06;
    top: 30%;
    right: 10%;
    animation: pulseGlow 10s ease-in-out infinite 2s;
  }

  .orb-3 {
    width: 250px;
    height: 250px;
    background: var(--color-accent);
    opacity: 0.05;
    bottom: 10%;
    left: 50%;
    animation: pulseGlow 7s ease-in-out infinite 4s;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.3) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.04;
  }

  .shape {
    position: absolute;
    opacity: 0.4;
  }

  .shape-1 {
    width: 60px;
    height: 60px;
    border: 1px solid #36758840;
    border-radius: 12px;
    top: 20%;
    right: 20%;
    animation: float1 12s ease-in-out infinite;
  }

  .shape-2 {
    width: 30px;
    height: 30px;
    border: 1px solid #F3923740;
    border-radius: 50%;
    bottom: 25%;
    left: 12%;
    animation: float2 10s ease-in-out infinite 1s;
  }

  .shape-3 {
    width: 45px;
    height: 45px;
    border: 1px solid #36758830;
    top: 60%;
    right: 30%;
    transform: rotate(45deg);
    opacity: 0.3;
    animation: float3 14s ease-in-out infinite 3s;
  }
</style>
