---
import Logo from './ui/Logo.astro';
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();

const socials = [
  { label: 'GitHub',   href: 'https://github.com/gabrielulacio',        icon: 'mdi:github' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/gabrielulacio',   icon: 'mdi:linkedin' },
  { label: 'Email',    href: 'mailto:geur0308@gmail.com',               icon: 'mdi:email-outline' },
];
---

<footer class="mt-24 border-t" style="border-color: var(--color-border);" role="contentinfo">
  <div class="mx-auto max-w-6xl px-6 py-12 flex flex-col items-center gap-6">

    <Logo size={32} />


    <ul class="flex items-center gap-5" role="list">
      {socials.map(({ label, href, icon }) => (
        <li>
          <a
            href={href}
            target={href.startsWith('mailto') ? undefined : '_blank'}
            rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            aria-label={label}
            class="social-icon transition-all duration-200"
            style="color: var(--color-text-muted);"
          >
            <Icon name={icon} class="w-5 h-5" aria-hidden="true" />
          </a>
        </li>
      ))}
    </ul>

    <p class="text-xs" style="color: var(--color-text-dim);">
      &copy; {year} Gabriel Ulacio
    </p>

  </div>
</footer>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.social-icon').forEach(a => {
    a.addEventListener('mouseenter', () => {
      a.style.color = 'var(--color-accent)';
      a.style.transform = 'translateY(-3px)';
    });
    a.addEventListener('mouseleave', () => {
      a.style.color = 'var(--color-text-muted)';
      a.style.transform = '';
    });
  });
</script>
