---

import { Icon } from 'astro-icon/components';

export interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  date: string;
  featured?: boolean;
  liveUrl?: string;
  repoUrl?: string;
  image?: string;
  cardImage?: string;
  modalImage?: string;
}

const {
  slug,
  title,
  description,
  tags,
  date,
  featured = false,
  liveUrl,
  repoUrl,
  image,
  cardImage,
  modalImage,
} = Astro.props;

const cardCoverImage = cardImage ?? image ?? modalImage;
const modalCoverImage = modalImage ?? cardImage ?? image;

// ID único para vincular tarjeta → modal sin colisiones
const modalId = `modal-${slug.replace(/[^a-z0-9]/gi, '-')}`;

const formattedDate = new Date(date).toLocaleDateString('es-VE', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<!-- ========= TARJETA =========-->
<article
  class="group relative flex flex-col bg-[#111111] border border-[#2D2D2D] rounded-lg overflow-hidden
         hover:border-[#ACE600]/50 hover:shadow-[0_0_24px_-4px_rgba(172,230,0,0.18)]
         transition-all duration-300 cursor-pointer"
  aria-label={`Proyecto: ${title}`}
  data-modal-trigger={modalId}
  tabindex="0"
  role="button"
>
  <!-- Imagen de portada -->
  <div class="overflow-hidden h-44 bg-[#0A0A0A]">
    {cardCoverImage ? (
      <img
        src={cardCoverImage}
        alt={`Portada de ${title}`}
        class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-[#0f0f0f]">
        <Icon name="mdi:code-braces" class="w-10 h-10 text-[#2D2D2D]" aria-hidden="true" />
      </div>
    )}
  </div>

  <div class="flex flex-col flex-1 p-5 gap-3">

    <!-- Título + badge -->
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-sm font-semibold text-[#F1F1F1] leading-snug group-hover:text-[#ACE600] transition-colors duration-200">
        {title}
      </h3>
      {featured && (
        <span class="shrink-0 text-[10px] font-mono uppercase tracking-widest text-[#ACE600] border border-[#ACE600]/40 rounded px-2 py-0.5 bg-[#ACE600]/5">
          Destacado
        </span>
      )}
    </div>

    <!-- Descripción breve -->
    <p class="text-xs text-[#A3A3A3] leading-relaxed line-clamp-2">
      {description}
    </p>

    <!-- Tags (máx. 4 visibles) -->
    <ul class="flex flex-wrap gap-1.5 mt-auto" role="list">
      {tags.slice(0, 4).map((tag) => (
        <li class="font-mono text-[10px] text-[#A3A3A3] border border-[#2D2D2D] rounded px-2 py-0.5 bg-[#0A0A0A]">
          {tag}
        </li>
      ))}
      {tags.length > 4 && (
        <li class="font-mono text-[10px] text-[#A3A3A3] border border-[#2D2D2D] rounded px-2 py-0.5 bg-[#0A0A0A]">
          +{tags.length - 4}
        </li>
      )}
    </ul>

    <!-- Pie de tarjeta  -->
    <div class="flex items-center justify-end pt-2 border-t border-[#2D2D2D]">
      <span class="text-xs font-mono text-[#ACE600] group-hover:underline underline-offset-2">
        Ver detalles →
      </span>
    </div>

  </div>
</article>


<!-- ========= MODAL ========= -->
<div
  id={modalId}
  class="modal-backdrop fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-8"
  aria-modal="true"
  role="dialog"
  aria-labelledby={`${modalId}-title`}
>
  <!-- Overlay oscuro -->
  <div class="modal-overlay absolute inset-0 bg-black/80 backdrop-blur-sm" data-modal-close={modalId}></div>

  <!-- Panel -->
  <div class="modal-panel relative w-full max-w-2xl max-h-[90vh] flex flex-col bg-[#121212] border border-[#2D2D2D] rounded-xl overflow-hidden shadow-[0_0_60px_-10px_rgba(172,230,0,0.2)]">

    <!-- Imagen del modal -->
    {modalCoverImage && (
      <div class="shrink-0 border-b border-[#2D2D2D]">
        <img
          src={modalCoverImage}
          alt={`Portada de ${title}`}
          class="block w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}

    <!-- Cabecera -->
    <div class="flex items-start justify-between gap-4 px-6 pt-5 pb-3 shrink-0">
      <div class="flex flex-col gap-1">
        <h2 id={`${modalId}-title`} class="text-xl font-bold text-[#F1F1F1] leading-tight">
          {title}
        </h2>
        <time class="font-mono text-xs text-[#A3A3A3]" datetime={date}>{formattedDate}</time>
      </div>
      <button
        class="shrink-0 p-1.5 rounded text-[#A3A3A3] hover:text-[#ACE600] hover:bg-[#ACE600]/10 transition-colors"
        data-modal-close={modalId}
        aria-label="Cerrar"
      >
        <Icon name="mdi:close" class="w-5 h-5" />
      </button>
    </div>

    <!-- Tags completos -->
    <ul class="flex flex-wrap gap-2 px-6 pb-3 shrink-0" role="list">
      {tags.map((tag) => (
        <li class="font-mono text-[11px] text-[#ACE600] border border-[#ACE600]/35 rounded px-2 py-0.5 bg-[#ACE600]/10">
          {tag}
        </li>
      ))}
    </ul>

    <div class="border-t border-[#2D2D2D] mx-6 shrink-0"></div>

    <!-- Contenido Markdown (scrollable) -->
    <div class="prose-modal overflow-y-auto px-6 py-5 flex-1">
      <slot />
    </div>

    <!-- Footer con enlaces -->
    {(repoUrl || liveUrl) && (
      <div class="flex items-center gap-3 px-6 py-4 border-t border-[#2D2D2D] shrink-0 bg-[#0f0f0f]">
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#F1F1F1] border border-[#2D2D2D] rounded px-3 py-1.5 hover:border-[#ACE600] hover:text-[#ACE600] active:scale-95 transition-all duration-200"
          >
            <Icon name="mdi:github" class="w-4 h-4" aria-hidden="true" />
            Ver en GitHub
          </a>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#0A0A0A] bg-[#ACE600] rounded px-3 py-1.5 hover:bg-[#c4f500] transition-colors glow-accent"
          >
            <Icon name="mdi:open-in-new" class="w-4 h-4" aria-hidden="true" />
            Ver en vivo
          </a>
        )}
      </div>
    )}

  </div>
</div>


<!-- ══════════════════════════════════════════════════════════════
     ESTILOS SCOPED
══════════════════════════════════════════════════════════════ -->
<style>
  .modal-backdrop.is-open { display: flex; }

  .modal-panel {
    animation: modal-in 0.2s ease forwards;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.96) translateY(8px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);   }
  }

  .prose-modal { color: #A3A3A3; font-size: 0.875rem; line-height: 1.75; }
  .prose-modal :where(h2,h3,h4) { color: #F1F1F1; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose-modal h2 { font-size: 1.1rem; }
  .prose-modal h3 { font-size: 1rem; }
  .prose-modal p  { margin-bottom: 1rem; }
  .prose-modal strong { color: #F1F1F1; }
  .prose-modal em     { color: #ACE600; font-style: italic; }
  .prose-modal a  { color: #ACE600; text-decoration: underline; text-underline-offset: 3px; }
  .prose-modal ul, .prose-modal ol { padding-left: 1.25rem; margin-bottom: 1rem; }
  .prose-modal li { margin-bottom: 0.3rem; }
  .prose-modal ul > li::marker { color: #ACE600; }
  .prose-modal code {
    font-family: 'JetBrains Mono', monospace; font-size: 0.8em;
    background: #0A0A0A; border: 1px solid #2D2D2D; border-radius: 3px;
    padding: 0.1em 0.35em; color: #ACE600;
  }
  .prose-modal pre {
    background: #0A0A0A; border: 1px solid #2D2D2D; border-radius: 6px;
    padding: 1rem; overflow-x: auto; margin-bottom: 1rem;
  }
  .prose-modal pre code { background: none; border: none; padding: 0; color: #F1F1F1; }

  :global(body.modal-open) { overflow: hidden; }
</style>


<!-- ===== LÓGICA JS (vanilla, mínima) ===== -->
<script define:vars={{ modalId }}>
  const card    = document.querySelector(`[data-modal-trigger="${modalId}"]`);
  const modal   = document.getElementById(modalId);
  const closers = modal?.querySelectorAll(`[data-modal-close="${modalId}"]`);

  function openModal() {
    modal?.classList.add('is-open');
    document.body.classList.add('modal-open');
  }

  function closeModal() {
    modal?.classList.remove('is-open');
    document.body.classList.remove('modal-open');
  }

  card?.addEventListener('click', openModal);
  card?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(); }
  });

  closers?.forEach((el) => el.addEventListener('click', closeModal));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal();
  });
</script>