---
import Logo from './ui/Logo.astro';

const navLinks = [
  { label: 'Inicio',      href: '/'},
  { label: 'Proyectos',   href: '/#proyectos'},
  { label: 'Habilidades', href: '/#habilidades'},
  { label: 'Contacto',    href: '/#contacto'},
];
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
  style="background: transparent;"
  role="banner"
>
  <div class="mx-auto max-w-6xl px-6 h-[72px] flex items-center justify-between">

    <a href="/" aria-label="Inicio" class="flex items-center gap-3">
      <Logo size={28} color="#367588" />
      <span
        class="text-lg font-bold tracking-wide hidden sm:block"
        style="color: var(--color-text); font-family: var(--font-display);"
      >
        Gabriel Ulacio
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="nav-link text-sm font-medium transition-colors duration-200"
          style="color: var(--color-text-muted); font-family: var(--font-display);"
        >
          {label}
        </a>
      ))}
    </nav>

    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      style="color: var(--color-text-muted);"
    >
      <span class="block w-5 h-px bg-current transition-all duration-200 origin-center" id="bar1"></span>
      <span class="block w-5 h-px bg-current transition-all duration-200"               id="bar2"></span>
      <span class="block w-5 h-px bg-current transition-all duration-200 origin-center" id="bar3"></span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="md:hidden hidden flex-col px-6 py-4 gap-4 border-t"
    style="border-color: var(--color-border); background: rgba(28,28,28,0.95);"
    aria-label="Mobile navigation"
  >
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class="text-sm font-medium py-1 transition-colors duration-200"
        style="color: var(--color-text-muted); font-family: var(--font-display);"
      >
        {label}
      </a>
    ))}
  </nav>
</header>

<script>
  const header = document.getElementById('site-header')!;

  function updateHeader() {
    if (window.scrollY > 40) {
      header.style.background = 'rgba(28,28,28,0.85)';
      header.style.backdropFilter = 'blur(16px)';
      header.style.borderBottom = '1px solid var(--color-border)';
    } else {
      header.style.background = 'transparent';
      header.style.backdropFilter = '';
      header.style.borderBottom = '';
    }
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  const homeLinks = document.querySelectorAll<HTMLAnchorElement>('a[href="/"]');
  homeLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.location.pathname === '/') {
        e.preventDefault();
        history.replaceState(null, '', '/');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  });

  const btn  = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    menu.classList.toggle('flex', open);
    btn.setAttribute('aria-expanded', String(open));
    bar1.style.transform = open ? 'translateY(6px) rotate(45deg)'  : '';
    bar2.style.opacity   = open ? '0'                               : '1';
    bar3.style.transform = open ? 'translateY(-6px) rotate(-45deg)' : '';
  });

  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
    link.addEventListener('mouseenter', () => {
      link.style.color = 'transparent';
      link.style.backgroundClip = 'text';
      link.style.webkitBackgroundClip = 'text';
      link.style.backgroundImage = 'radial-gradient(circle at 50% 50%, #F39237 0%, #367588 70%)';
    });
    link.addEventListener('mousemove', (e) => {
      const r = link.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width * 100).toFixed(1);
      const y = ((e.clientY - r.top) / r.height * 100).toFixed(1);
      link.style.backgroundImage = `radial-gradient(circle at ${x}% ${y}%, #F39237 0%, #367588 70%)`;
    });
    link.addEventListener('mouseleave', () => {
      link.style.color = 'var(--color-text-muted)';
      link.style.backgroundClip = '';
      link.style.webkitBackgroundClip = '';
      link.style.backgroundImage = '';
    });
  });
</script>
